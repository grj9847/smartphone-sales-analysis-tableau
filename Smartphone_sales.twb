      <column datatype='string' name='[Brands]' role='dimension' type='nominal' />
      <column caption='Rating Category' datatype='string' name='[Calculation_0388713386827780]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Rating] &gt;= 4.5 THEN &quot;Excellent&quot;&#13;&#10;ELSEIF [Rating] &gt;= 4.0 THEN &quot;Good&quot;&#13;&#10;ELSEIF [Rating] &gt;= 3.5 THEN &quot;Average&quot;&#13;&#10;ELSE &quot;Poor&quot;&#13;&#10;END' />
      </column>
      <column caption='Price Category' datatype='string' name='[Calculation_0388713387122693]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Selling Price] &lt; 10000 THEN &quot;Budget&quot;&#13;&#10;ELSEIF [Selling Price] &lt; 30000 THEN &quot;Mid Range&quot;&#13;&#10;ELSEIF [Selling Price] &lt; 60000 THEN &quot;Premium&quot;&#13;&#10;ELSE &quot;Ultra Premium&quot;&#13;&#10;END' />
      </column>
      <column caption='Calculation1' datatype='integer' name='[Calculation_0388713387520007]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Models])' />
      </column>
      <column caption='Average Rating' datatype='real' name='[Calculation_0388713387724808]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Rating])' />
      </column>
      <column caption='Average Selling Price' datatype='real' name='[Calculation_0388713387786249]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Selling Price])' />
      </column>
      <column caption='Total Revenue' datatype='integer' name='[Calculation_0388713387855882]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Selling Price])' />
      </column>
      <column caption='Total MRP' datatype='integer' name='[Calculation_0388713387921419]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Original Price])' />
      </column>
      <column caption='Discount %' datatype='real' name='[Calculation_0388713388060685]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Original Price] - [Selling Price]) / [Original Price] * 100' />
      </column>
      <column caption='Average Price per Brand' datatype='real' name='[Calculation_0388713388212238]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Selling Price])' />
      </column>
      <column aggregation='None' datatype='integer' name='[Discount % (bin)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='0' formula='[Calculation_0388713388060685]' peg='0' size='8.5' />
      </column>
